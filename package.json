{
  "name": "gutu-lib-analytics",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/libraries/*"
  ],
  "scripts": {
    "build": "bun run --cwd framework/libraries/analytics build",
    "typecheck": "bun run --cwd framework/libraries/analytics typecheck",
    "lint": "bun run --cwd framework/libraries/analytics lint",
    "test": "bun run --cwd framework/libraries/analytics test",
    "test:unit": "bun run --cwd framework/libraries/analytics test:unit",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs"
  }
}
